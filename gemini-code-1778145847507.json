{
  "assistant_name": "FreshAI",
  "version": "1.0.0",
  "creator": "Luay",
  "github_user": "luauy",
  "settings": {
    "theme": "minimalist",
    "framework_priority": ["Next.js", "React", "Tailwind CSS"],
    "styling_standard": "Utility-first (Tailwind)",
    "git_flow": {
      "auto_commit": true,
      "commit_prefix": "🍃 fresh:",
      "default_branch": "main"
    }
  },
  "rules": [
    "Prioritize accessibility (a11y) in web designs.",
    "Use functional components and Hooks for React.",
    "Always check for mobile responsiveness."
    "Swearing isn't good."
    "Dont do Malicious Hacks and tricks that makes your AI a living Hell."
  ]
}
